{
  "project_id": "ezhu-ponyatno",
  "display_name": "Ежу понятно",
  "description": "YouTube → транскрипция → LLM summary → TTS → render shorts → субтитры → ёж-спикер → финальное видео. Полный пайплайн генерации видео-саммари с озвучкой и аватаром.",
  "enabled": true,
  "input_fields": [
    {
      "key": "url",
      "label": "Ссылка на YouTube",
      "type": "text",
      "required": true,
      "placeholder": "https://www.youtube.com/watch?v=..."
    },
    {
      "key": "speech_rate",
      "label": "Скорость речи",
      "type": "text",
      "required": false,
      "default": "1.2",
      "placeholder": "1.2"
    },
    {
      "key": "voice",
      "label": "Голос TTS",
      "type": "select",
      "required": false,
      "default": "Tur_24000",
      "options": ["Tur_24000", "Nec_24000", "Bys_24000", "May_24000", "Ost_24000", "Pon_24000", "Kin_24000"]
    },
    {
      "key": "landscape",
      "label": "Ландшафтный формат (16:9)",
      "type": "checkbox",
      "required": false,
      "default": false
    },
    {
      "key": "telegram_enabled",
      "label": "Опубликовать в Telegram",
      "type": "checkbox",
      "required": false,
      "default": false
    }
  ],
  "jobs": [
    {
      "job_id": "run_pipeline",
      "title": "Запуск пайплайна",
      "order": 10,
      "job_type": "run_pipeline",
      "enabled": true,
      "manual_run_allowed": true,
      "cron_allowed": false,
      "config": {
        "api_url": "http://141.136.44.9:8000",
        "run_endpoint": "/jobs",
        "status_endpoint": "/jobs/{job_id}"
      }
    }
  ],
  "publish_targets": [],
  "integration": {
    "api_url": "http://141.136.44.9:8000",
    "integration_type": "api",
    "jobs_list_endpoint": "/jobs",
    "job_detail_endpoint": "/jobs/{job_id}",
    "artifacts_endpoint": "/jobs/{job_id}/artifacts/{key}",
    "job_cancel_endpoint": "/jobs/{job_id}/cancel",
    "auto_sync": true
  },
  "publish_bindings": [],
  "config": {
    "api_url": "http://141.136.44.9:8000",
    "integration_type": "api"
  }
}
